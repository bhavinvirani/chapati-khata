# Copy this file to ".env" and fill in your project's values.
# Both come from Supabase → Project Settings → API.
# These are PUBLIC by design (the anon key is meant to ship in the frontend);
# access is controlled by Row-Level Security, not by hiding this key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: only for GitHub Pages sub-path hosting, e.g. "/chapati-khata/"
# VITE_BASE=/
